# Electron runtime settings
# prebuild-install vai baixar binários pré-compilados para Electron 33
# em vez de tentar compilar para a versão do Node do sistema.
runtime=electron
target=33.2.0
disturl=https://electronjs.org/headers

# Força MSVC v143 (VS2022) em vez de ClangCL.
# No Node 24+, o default no Windows é ClangCL, que falha com /LTCG:INCREMENTAL.
# Com v143 o node-gyp usa cl.exe e link.exe do MSVC, que compilam corretamente.
msbuild_toolset=v143
